endpoint            = "https://<proxmox-host>:8006"
api_token           = "<user>@<realm>!<token-id>=<secret>"  # realm: pam, pve, etc.
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

caddy_ip         = "192.168.1.<x>"
gateway          = "192.168.1.1"
proxmox_ssh_host = "<proxmox-public-ip>"
# proxmox_ssh_port = 22   # optional, default 22
# proxmox_ssh_user = "root"  # optional, default root
